<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A5A5A5"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".data_collection_end_game"
    tools:showIn="@layout/activity_data_collection_end_game"
    android:focusableInTouchMode="true"
    android:focusable="true">


    <TextView
        android:id="@+id/Other_TV"
        android:layout_width="266dp"
        android:layout_height="60dp"
        android:fontFamily="@font/bolt_regular"
        android:text="ROBOT"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="55sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.041" />

    <RadioGroup
        android:id="@+id/radioGroup3"
        android:layout_width="600dp"
        android:layout_height="98dp"
        android:orientation='horizontal'
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.73"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.406">

        <RadioButton
            android:id="@+id/other_TurretQuestionYes_RB"
            android:layout_width="15dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Yes"
            android:textSize="45sp" />

        <RadioButton
            android:id="@+id/other_TurretQuestionNo_RB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No"
            android:textSize="45sp"
            android:typeface="normal" />

    </RadioGroup>

    <TextView
        android:id="@+id/other_TrenchQuestion_TB"
        android:layout_width="674dp"
        android:layout_height="98dp"
        android:fontFamily="sans-serif"
        android:text="Do you have a turret?"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="45sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.318" />

    <EditText
        android:id="@+id/end_otherText_TB"
        android:layout_width="203dp"
        android:layout_height="79dp"
        android:editable="true"
        android:ems="10"
        android:inputType="number"
        android:text="1, 2, 3..."
        android:textSize="40sp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.892"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.19" />

    <TextView
        android:id="@+id/end_driveBase_TB"
        android:layout_width="515dp"
        android:layout_height="106dp"
        android:fontFamily="sans-serif"
        android:text="How many fuel do you shoot in one shot:"
        android:textAlignment="textStart"
        android:textColor="#000000"
        android:textSize="45sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.263"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.167" />

    <TextView
        android:id="@+id/other_BumpQuestion_TB"
        android:layout_width="757dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="Do you shoot while moving?"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="45sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.372"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.514" />

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="600dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:requiresFadingEdge="vertical"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.616">

        <RadioButton
            android:id="@+id/other_ShootQuestionYes_RB"
            android:layout_width="266dp"
            android:layout_height="wrap_content"
            android:text="Yes"
            android:textSize="45sp" />

        <RadioButton
            android:id="@+id/other_ShootQuestionNo_RB"
            android:layout_width="215dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="No"
            android:textSize="45sp" />

    </RadioGroup>

    <Button
        android:id="@+id/To_Submission_B"
        android:layout_width="591dp"
        android:layout_height="172dp"
        android:layout_marginStart="131dp"
        android:layout_marginEnd="130dp"
        android:fontFamily="@font/bolt_regular"
        android:text="To Submission"
        android:textSize="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.906" />


</android.support.constraint.ConstraintLayout>